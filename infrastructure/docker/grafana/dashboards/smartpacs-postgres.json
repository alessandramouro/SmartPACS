{
  "uid": "smartpacs-postgres",
  "title": "SmartPACS - PostgreSQL",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["smartpacs"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Postgres Up",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "refId": "A", "expr": "pg_up" }]
    },
    {
      "id": 2,
      "title": "Database Size",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "pg_database_size_bytes{datname=\"smartpacs\"}" }]
    },
    {
      "id": 3,
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "refId": "A", "expr": "pg_stat_database_numbackends{datname=\"smartpacs\"}", "legendFormat": "connections" }
      ]
    },
    {
      "id": 4,
      "title": "Transactions/sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "refId": "A", "expr": "rate(pg_stat_database_xact_commit{datname=\"smartpacs\"}[5m])", "legendFormat": "commits/s" },
        { "refId": "B", "expr": "rate(pg_stat_database_xact_rollback{datname=\"smartpacs\"}[5m])", "legendFormat": "rollbacks/s" }
      ]
    },
    {
      "id": 5,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(pg_stat_database_blks_hit{datname=\"smartpacs\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{datname=\"smartpacs\"}[5m])) + sum(rate(pg_stat_database_blks_read{datname=\"smartpacs\"}[5m])))",
          "legendFormat": "hit ratio"
        }
      ]
    }
  ]
}
