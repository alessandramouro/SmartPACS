# ─── SmartPACS Edge Agent Configuration ───────────────────────────────────
# Copy this file to .env and fill in the values.
# Obtain EDGE_AGENT_ID and EDGE_AGENT_API_KEY after registering the agent
# via the SmartPACS portal (Agentes Edge → Registrar Agente).

# ─── Agent identity (set after registration) ────────────────────────────────
# Option A — manual registration via the portal (Agentes Edge → Registrar Agente):
EDGE_AGENT_ID=
EDGE_AGENT_CLINIC_ID=
EDGE_AGENT_API_KEY=

# Option B — zero-touch provisioning: generate a one-time token in the portal
# (Agentes Edge → Gerar Token de Provisionamento), set ONLY this var, and leave
# EDGE_AGENT_ID/EDGE_AGENT_API_KEY blank — the agent self-registers on first boot
# and persists its credentials to ./storage/credentials.json (no further .env edit needed).
EDGE_AGENT_ENROLLMENT_TOKEN=

# ─── Cloud API connection ────────────────────────────────────────────────────
CLOUD_API_URL=http://localhost:3001
# Production example: https://api.smartpacs.com.br

# ─── Local HTTP port (management API) ───────────────────────────────────────
AGENT_HTTP_PORT=3002

# ─── DICOM SCP settings ─────────────────────────────────────────────────────
DICOM_AE_TITLE=SMARTPACS
DICOM_SCP_PORT=104
# Comma-separated list of allowed calling AE Titles — informational only in this
# dcmtk build (storescp has no CLI option to enforce it); leave empty to allow all
DICOM_ALLOWED_AE_TITLES=

# ─── DICOM Worklist (C-FIND SCU + local Worklist SCP) ────────────────────────
DICOM_WORKLIST_ENABLED=false
# host:port of the clinic's HIS/RIS C-FIND SCP
DICOM_WORKLIST_HIS_URL=
# Called AE title of the HIS/RIS worklist provider
DICOM_WORKLIST_HIS_AE_TITLE=ANY-SCP
# Port this agent's own Worklist SCP (wlmscpfs) listens on, for the modality to query
DICOM_WORKLIST_LOCAL_PORT=105
DICOM_WORKLIST_DIR=./storage/worklist
DICOM_WORKLIST_CACHE_MINUTES=5

# ─── Storage paths ───────────────────────────────────────────────────────────
STORAGE_PATH=./storage
DICOM_RECEIVED_DIR=./storage/received
DICOM_PROCESSED_DIR=./storage/processed
DICOM_FAILED_DIR=./storage/failed

# ─── Sync settings ───────────────────────────────────────────────────────────
HEARTBEAT_INTERVAL=15
SYNC_INTERVAL=30
MAX_CONCURRENT_UPLOADS=3
CHUNK_SIZE_MB=8

# ─── Redis (optional — for Bull queue; if absent, in-memory fallback is used) ─
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ─── OAuth credentials (mirrored from cloud storage config) ─────────────────
# These are automatically synced from the cloud when the agent starts.
# You do NOT need to set them manually.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_CLIENT_SECRET=
