# ============================================================
# SmartPACS - Environment Variables Example
# Copy to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
APP_NAME=SmartPACS
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
EDGE_AGENT_URL=http://localhost:3002

# Database - PostgreSQL
DATABASE_URL=postgresql://smartpacs:smartpacs@localhost:5432/smartpacs?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (AES-256)
ENCRYPTION_KEY=your-32-char-encryption-key-here!
ENCRYPTION_IV=your-16-char-iv!!

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="SmartPACS <noreply@smartpacs.com>"

# Google Drive OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/google/callback

# Microsoft OneDrive OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/v1/auth/microsoft/callback

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=smartpacs-api
PROMETHEUS_PORT=9090

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File Storage (local dev)
STORAGE_LOCAL_PATH=./storage
STORAGE_MAX_FILE_SIZE_MB=2048

# Edge Agent specific
EDGE_AGENT_ID=local-dev-agent
EDGE_AGENT_CLINIC_ID=
EDGE_AGENT_API_KEY=
DICOM_SCP_PORT=104
DICOM_AE_TITLE=SMARTPACS

# Feature Flags
FEATURE_MFA=false
FEATURE_AUDIT_LOGS=true
FEATURE_WEBHOOKS=true
FEATURE_ANONYMIZATION=false

# Sentry (optional)
SENTRY_DSN=

# Admin seed
SEED_ADMIN_EMAIL=admin@smartpacs.com
SEED_ADMIN_PASSWORD=Admin@123456!
